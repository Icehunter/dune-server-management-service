#!/usr/bin/env bash
set -euo pipefail
trap 'echo "[$(date -Is)] ERROR: unexpected failure at line $LINENO (exit $?)" >&2' ERR
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# shellcheck source=lib/dune-service-common.sh
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/lib/dune-service-common.sh"
dune_export_kubeconfig

lock=/tmp/dune-daily-battlegroup-restart.lock
dry_run=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) dry_run=true; shift ;;
    *) echo "unknown argument: $1" >&2; exit 2 ;;
  esac
done
exec 9>"$lock"
if ! flock -n 9; then
  echo "[$(date -Is)] another daily restart is already running; exiting"
  exit 0
fi
mapfile -t namespaces < <(kubectl get ns --no-headers -o custom-columns=NAME:.metadata.name | grep '^funcom-seabass-' || true)
if [[ ${#namespaces[@]} -ne 1 ]]; then
  echo "[$(date -Is)] ERROR: expected exactly one battlegroup namespace, found ${#namespaces[@]}" >&2
  printf '  %s\n' "${namespaces[@]}" >&2
  exit 1
fi
ns="${namespaces[0]}"
bg="${ns#funcom-seabass-}"
if [[ "$dry_run" == true ]]; then
  echo "dry_run=true bg=$bg ns=$ns would_stop_wait_start=true"
  exit 0
fi
count_server_pods() {
  kubectl get pods -n "$ns" -o json | python3 -c 'import json,sys; d=json.load(sys.stdin); print(sum(1 for p in d.get("items",[]) if "-sg-" in p["metadata"]["name"] and "-pod-" in p["metadata"]["name"] and p["metadata"].get("deletionTimestamp") is None))'
}
ready_summary() {
  kubectl get battlegroup "$bg" -n "$ns" -o json | python3 -c 'import json,sys; d=json.load(sys.stdin); st=d.get("status",{}); servers=st.get("servers",[]) or []; ready=sum(1 for s in servers if s.get("ready") is True and s.get("phase") == "Running"); print(f"phase={st.get('phase','')} serverGroupPhase={st.get('serverGroupPhase','')} ready={ready}/{st.get('size',len(servers))}")'
}

echo "[$(date -Is)] stopping battlegroup bg=$bg ns=$ns"
/home/dune/.dune/bin/battlegroup stop

timeout=900
elapsed=0
interval=10
while (( elapsed < timeout )); do
  pods=$(count_server_pods)
  stop_value=$(kubectl get battlegroup "$bg" -n "$ns" -o jsonpath='{.spec.stop}' 2>/dev/null || true)
  echo "[$(date -Is)] waiting stopped elapsed=${elapsed}s stop=${stop_value:-?} server_pods=$pods"
  if [[ "$stop_value" == "true" && "$pods" == "0" ]]; then
    break
  fi
  sleep "$interval"
  elapsed=$((elapsed + interval))
done
if (( elapsed >= timeout )); then
  echo "[$(date -Is)] ERROR: timeout waiting for battlegroup to stop" >&2
  exit 1
fi

echo "[$(date -Is)] starting battlegroup bg=$bg ns=$ns"
/home/dune/.dune/bin/battlegroup start

timeout=1200
elapsed=0
while (( elapsed < timeout )); do
  summary=$(ready_summary)
  echo "[$(date -Is)] waiting running elapsed=${elapsed}s $summary"
  if python3 - "$summary" <<'CHECK'
import re, sys
s = sys.argv[1]
m = re.search(r"ready=(\d+)/(\d+)", s)
ok = "serverGroupPhase=Running" in s and m and int(m.group(1)) == int(m.group(2)) and int(m.group(2)) > 0
sys.exit(0 if ok else 1)
CHECK
  then
    echo "[$(date -Is)] battlegroup restart complete $summary"
    exit 0
  fi
  sleep "$interval"
  elapsed=$((elapsed + interval))
done
echo "[$(date -Is)] ERROR: timeout waiting for battlegroup to become healthy/running" >&2
exit 1
